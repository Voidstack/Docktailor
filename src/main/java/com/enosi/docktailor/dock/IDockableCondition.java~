package com.enosi.docktailor.dock;

/**
 * Définis une condition qui à tester pour savoir si la fenêtre dois exister.
 * Par exemple pour une fenetre qui doit exister uniquement en debug mode.
 */
public interface IDockableCondition {
    /**
     * Condition qui définis l'existance de la fenêtre dans le contexte.
     * @return boolean
     */
    boolean isExistDansLeContext();
}
